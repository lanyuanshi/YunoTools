<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />

    <application
        android:name=".YunoApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.YunoTools"
        android:usesCleartextTraffic="true"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.video.VideoParseActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".ui.tools.RandomQuoteActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".ui.video.ParseResultActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".ui.video.ImageSetResultActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".ui.profile.ProfileActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".ui.profile.ParseHistoryActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".ui.profile.SettingsActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".ui.image.ImageCompressActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".ui.image.QRCodeActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".ui.image.GridCropActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".ui.media.AudioSeparateActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".ui.media.VideoTrimActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".ui.tools.BarrageActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".ui.tools.ClockActivity"
            android:screenOrientation="landscape" />
        <activity
            android:name=".ui.tools.AnswerBookActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".ui.video.PlayerActivity"
            android:configChanges="orientation|screenSize|smallestScreenSize"
            android:screenOrientation="unspecified" />
    </application>
</manifest>