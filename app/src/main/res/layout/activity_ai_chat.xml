<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#F2F2F7" android:orientation="vertical">
 <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:gravity="center_vertical" android:orientation="horizontal" android:paddingHorizontal="16dp">
  <ImageButton android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_back" app:tint="#1C1C1E"/>
  <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="AI聊天" android:textColor="#1C1C1E" android:textSize="17sp" android:textStyle="bold"/>
  <ImageButton android:id="@+id/btnClear" android:layout_width="40dp" android:layout_height="40dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_history" app:tint="#8E8E93"/>
 </LinearLayout>
 <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingHorizontal="16dp" android:paddingBottom="8dp">
  <EditText android:id="@+id/etApiKey" android:layout_width="match_parent" android:layout_height="44dp" android:background="@drawable/bg_input_round" android:hint="OpenRouter API Key" android:inputType="textPassword" android:paddingHorizontal="14dp" android:singleLine="true" android:textSize="13sp"/>
  <EditText android:id="@+id/etModel" android:layout_width="match_parent" android:layout_height="44dp" android:layout_marginTop="8dp" android:background="@drawable/bg_input_round" android:hint="模型ID" android:paddingHorizontal="14dp" android:singleLine="true" android:textSize="13sp"/>
 </LinearLayout>
 <ScrollView android:id="@+id/scrollMessages" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:fillViewport="true"><LinearLayout android:id="@+id/messageContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingVertical="10dp"/></ScrollView>
 <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@android:color/white" android:gravity="bottom" android:orientation="horizontal" android:padding="12dp">
  <EditText android:id="@+id/etInput" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:background="@drawable/bg_input_round" android:hint="输入消息..." android:maxLines="3" android:paddingHorizontal="14dp" android:textSize="15sp"/>
  <com.google.android.material.button.MaterialButton android:id="@+id/btnSend" android:layout_width="72dp" android:layout_height="48dp" android:layout_marginStart="10dp" android:text="发送" android:textColor="@android:color/white" app:backgroundTint="#007AFF" app:cornerRadius="16dp"/>
 </LinearLayout>
</LinearLayout>
