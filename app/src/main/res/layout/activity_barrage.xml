<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#000000" android:fitsSystemWindows="false">
    <FrameLayout android:id="@+id/barrageContainer" android:layout_width="match_parent" android:layout_height="match_parent" />
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="bottom" android:background="#CC000000" android:orientation="vertical" android:padding="14dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
            <ImageButton android:id="@+id/btnBack" android:layout_width="42dp" android:layout_height="42dp" android:background="@android:color/transparent" android:src="@drawable/ic_back" />
            <EditText android:id="@+id/etBarrageText" android:layout_width="0dp" android:layout_height="48dp" android:layout_marginStart="8dp" android:layout_weight="1" android:hint="输入弹幕文字" android:singleLine="true" android:text="尤诺工具箱" android:textColor="#FFFFFF" android:textColorHint="#99FFFFFF" />
            <Button android:id="@+id/btnSendBarrage" android:layout_width="96dp" android:layout_height="48dp" android:layout_marginStart="8dp" android:text="发射" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:gravity="center_vertical" android:orientation="horizontal">
            <Button android:id="@+id/btnColorRed" android:layout_width="34dp" android:layout_height="34dp" android:text="" />
            <Button android:id="@+id/btnColorYellow" android:layout_width="34dp" android:layout_height="34dp" android:layout_marginStart="8dp" android:text="" />
            <Button android:id="@+id/btnColorGreen" android:layout_width="34dp" android:layout_height="34dp" android:layout_marginStart="8dp" android:text="" />
            <Button android:id="@+id/btnColorBlue" android:layout_width="34dp" android:layout_height="34dp" android:layout_marginStart="8dp" android:text="" />
            <Button android:id="@+id/btnColorPurple" android:layout_width="34dp" android:layout_height="34dp" android:layout_marginStart="8dp" android:text="" />
            <Button android:id="@+id/btnColorWhite" android:layout_width="34dp" android:layout_height="34dp" android:layout_marginStart="8dp" android:text="" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="18dp" android:text="速度" android:textColor="#FFFFFF" />
            <SeekBar android:id="@+id/seekBarrageSpeed" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:max="10" android:progress="5" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
