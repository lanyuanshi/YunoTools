<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:id="@+id/profileRoot" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#F2F2F7" android:orientation="vertical">
    <LinearLayout android:layout_width="match_parent" android:layout_height="88dp" android:gravity="bottom|center_vertical" android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingBottom="12dp">
        <ImageButton android:id="@+id/btnBack" android:layout_width="42dp" android:layout_height="42dp" android:background="@drawable/bg_bottom_nav_capsule" android:padding="10dp" android:src="@drawable/ic_back" app:tint="#1C1C1E" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:text="个人资料" android:textColor="#111827" android:textSize="24sp" android:textStyle="bold" />
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_marginEnd="16dp" android:background="@drawable/bg_bottom_nav_capsule" android:elevation="3dp" android:gravity="center_vertical" android:orientation="horizontal" android:padding="16dp">
        <FrameLayout android:layout_width="58dp" android:layout_height="58dp" android:background="@drawable/bg_circle_blue_light"><ImageView android:layout_width="30dp" android:layout_height="30dp" android:layout_gravity="center" android:src="@drawable/ic_profile" app:tint="#1E88E5" /></FrameLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="14dp" android:layout_weight="1" android:orientation="vertical"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="YunoTools" android:textColor="#111827" android:textSize="18sp" android:textStyle="bold" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="短视频去水印 · 解析历史" android:textColor="#8A8F98" android:textSize="13sp" /></LinearLayout>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="18dp" android:layout_marginTop="20dp" android:layout_marginEnd="18dp" android:gravity="center_vertical" android:orientation="horizontal">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="解析历史" android:textColor="#111827" android:textSize="20sp" android:textStyle="bold" />
        <TextView android:id="@+id/tvHistoryCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="10dp" android:text="共 0 条" android:textColor="#8A8F98" android:textSize="13sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnClearHistory" android:layout_width="wrap_content" android:layout_height="36dp" android:minWidth="0dp" android:paddingStart="12dp" android:paddingEnd="12dp" android:text="清空" android:textColor="#6B7280" android:textSize="13sp" app:backgroundTint="#FFFFFF" app:cornerRadius="18dp" app:elevation="0dp" />
    </LinearLayout>
    <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:paddingStart="16dp" android:paddingTop="10dp" android:paddingEnd="16dp" android:paddingBottom="18dp">
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvHistory" android:layout_width="match_parent" android:layout_height="match_parent" android:clipToPadding="false" android:paddingBottom="8dp" />
        <LinearLayout android:id="@+id/emptyHistory" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical" android:visibility="gone"><ImageView android:layout_width="54dp" android:layout_height="54dp" android:src="@drawable/ic_clock" app:tint="#C4C9D1" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="暂无解析历史" android:textColor="#8A8F98" android:textSize="15sp" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="解析成功后会自动显示在这里" android:textColor="#B0B6C0" android:textSize="13sp" /></LinearLayout>
    </FrameLayout>
</LinearLayout>
