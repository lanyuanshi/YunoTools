<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/settingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F7"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:gravity="bottom|center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_bottom_nav_capsule"
                android:padding="10dp"
                android:src="@drawable/ic_back"
                app:tint="#1C1C1E" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="设置"
                android:textColor="#111827"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="AI聊天设置"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold" />
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:id="@+id/tvApiMode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="当前：使用默认 API"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="使用默认 API"
                            android:textColor="#1C1C1E"
                            android:textSize="15sp" />
                        <Switch
                            android:id="@+id/switchDefaultApi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true" />
                    </LinearLayout>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="默认端点：https://flxapi.cc；聊天页不再展示 API Key，只保留提示和模型选择。"
                        android:textColor="#8E8E93"
                        android:textSize="13sp" />
                    <LinearLayout
                        android:id="@+id/customApiPanel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical">
                        <EditText
                            android:id="@+id/etAiEndpoint"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:background="@drawable/bg_input_round"
                            android:hint="自定义端点，如 https://flxapi.cc"
                            android:paddingHorizontal="14dp"
                            android:singleLine="true"
                            android:textSize="13sp" />
                        <EditText
                            android:id="@+id/etAiApiKey"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_input_round"
                            android:hint="自定义 API Key"
                            android:paddingHorizontal="14dp"
                            android:singleLine="true"
                            android:textSize="13sp" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnResetAiSettings"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:text="恢复默认"
                            android:textColor="#007AFF"
                            app:backgroundTint="#EAF3FF"
                            app:cornerRadius="14dp" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSaveAiSettings"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:text="保存设置"
                            android:textColor="@android:color/white"
                            app:backgroundTint="#007AFF"
                            app:cornerRadius="14dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="主题"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCurrentTheme"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="当前：默认主题"
                android:textColor="#8E8E93"
                android:textSize="14sp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:columnCount="2">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/themeDefault"
                    android:layout_width="0dp"
                    android:layout_height="108dp"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="6dp"
                    android:layout_marginBottom="12dp"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="14dp">
                        <View android:layout_width="match_parent" android:layout_height="38dp" android:background="@drawable/bg_theme_swatch_default" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="默认" android:textColor="#111827" android:textSize="16sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/themeBlack"
                    android:layout_width="0dp"
                    android:layout_height="108dp"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="6dp"
                    android:layout_marginBottom="12dp"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="14dp">
                        <View android:layout_width="match_parent" android:layout_height="38dp" android:background="@drawable/bg_theme_swatch_black" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="黑色" android:textColor="#111827" android:textSize="16sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/themePink"
                    android:layout_width="0dp"
                    android:layout_height="108dp"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="6dp"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="14dp">
                        <View android:layout_width="match_parent" android:layout_height="38dp" android:background="@drawable/bg_theme_swatch_pink" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="粉色" android:textColor="#111827" android:textSize="16sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/themeBlue"
                    android:layout_width="0dp"
                    android:layout_height="108dp"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="6dp"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="14dp">
                        <View android:layout_width="match_parent" android:layout_height="38dp" android:background="@drawable/bg_theme_swatch_blue" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="蓝色" android:textColor="#111827" android:textSize="16sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/themeAmis"
                    android:layout_width="match_parent"
                    android:layout_height="116dp"
                    android:layout_columnSpan="2"
                    android:layout_marginTop="12dp"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="14dp">
                        <View android:layout_width="match_parent" android:layout_height="46dp" android:background="@drawable/bg_theme_swatch_amis" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="爱弥斯" android:textColor="#111827" android:textSize="16sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/themeYuno"
                    android:layout_width="match_parent"
                    android:layout_height="116dp"
                    android:layout_columnSpan="2"
                    android:layout_marginTop="12dp"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="14dp">
                        <View android:layout_width="match_parent" android:layout_height="46dp" android:background="@drawable/bg_theme_swatch_yuno" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="尤诺" android:textColor="#111827" android:textSize="16sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/themeFeiXue1"
                    android:layout_width="match_parent"
                    android:layout_height="116dp"
                    android:layout_columnSpan="2"
                    android:layout_marginTop="12dp"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="14dp">
                        <View android:layout_width="match_parent" android:layout_height="46dp" android:background="@drawable/bg_theme_swatch_fei_xue_1" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="绯雪1" android:textColor="#111827" android:textSize="16sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </GridLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
